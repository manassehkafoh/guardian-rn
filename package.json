{
  "name": "guardian-rn-workspace",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "codegen": "tsx packages/codegen/src/index.ts",
    "schema:validate": "tsx packages/codegen/src/validate.ts",
    "test": "jest --passWithNoTests",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit --project tsconfig.base.json",
    "build": "npm run codegen && npm run typecheck"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^8.57.0",
    "jest": "^29.0.0",
    "simple-git-hooks": "^2.11.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run codegen && git diff --exit-code packages/guardian-rn/src/generated packages/guardian-rn/android/src/main/kotlin/com/guardian/rn/generated packages/guardian-rn/ios/Generated"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^@noble/hashes/(.*)$": "<rootDir>/node_modules/@noble/hashes/$1.js",
      "^@guardian/rn/(.*)$": "<rootDir>/packages/guardian-rn/$1",
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "useESM": false
        }
      ]
    }
  }
}
